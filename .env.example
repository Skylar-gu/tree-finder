# Copy to .env and adjust. docker-compose reads these.
POSTGRES_USER=trees
POSTGRES_PASSWORD=trees
POSTGRES_DB=trees
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# API
API_HOST=0.0.0.0
API_PORT=8000
WEB_CONCURRENCY=4                 # gunicorn workers (prod)
ALLOWED_ORIGINS=*                 # lock down in prod, e.g. https://trees.example.com
SEED_SAMPLE=1                     # seed the bundled offline sample on first boot

# DB-free backends (no PostGIS), for local viewing — see DEPLOY.md:
#   LIVE_MODE=1  fetch REAL trees per city from open-data portals (10 US cities)
#   DEMO_MODE=1  serve the tiny bundled offline sample
LIVE_MODE=0
DEMO_MODE=0
LIVE_CITY_MAX=4000               # max trees cached per city in LIVE_MODE
LIVE_FETCH_RADIUS_M=9000         # fetch radius around each city center

# Optional: Mapillary token for the offline street-geometry enrichment (photos +
# measured branch geometry). Not needed to run the core app.
MAPILLARY_TOKEN=
